#include <iostream>
#include <string>
#include <vector>

struct Student {
    std::string name;
    int age;
    double averageScore;
};

int main() {
    Student students[5];
    int bestIndex = 0;
    for (int i = 1; i < 5; i++) {
        if (students[i].averageScore > students[bestIndex].averageScore) {
            bestIndex = i;
        }
    }
    
    std::cout << "Найкращий студент: " << students[bestIndex].name;
    return 0;
}
